generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  PARENT
  TUTOR
  ADMIN
}

enum BookingStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  COMPLETED
}

enum SessionStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile   StudentProfile?
  tutorProfile     TutorProfile?
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  jobOpenings      JobOpening[] @relation("JobOpenings")
  refreshToken     String?

  // Parent ↔ Student links (many-to-many)
  parentLinks       ParentStudentLink[] @relation("ParentUser")
  studentLinks      ParentStudentLink[] @relation("StudentUser")

  // Bookings made by this user (parent or student)
  bookings          Booking[]
}

model StudentProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearGroup   String?
  targetExams String?
  timezone    String  @default("Europe/London")

  sessions  Session[]
  progress  Progress[]
}

model TutorProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  hourlyRate         Float?
  verificationStatus VerificationStatus @default(PENDING)

  subjects     TutorSubject[]
  sessions     Session[]
  availability TutorAvailability[]
}

model Subject {
  id   String @id @default(uuid())
  name String @unique

  tutorSubjects TutorSubject[]
  sessions      Session[]
  progress      Progress[]
}

model TutorSubject {
  id             String       @id @default(uuid())
  tutorProfileId String
  tutorProfile   TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([tutorProfileId, subjectId])
  @@index([subjectId])
}

model Session {
  id          String        @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutorId     String
  tutor       TutorProfile  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  status      SessionStatus @default(UPCOMING)
  meetingLink   String?
  zoomMeetingId String?
  zoomJoinUrl   String?
  zoomPassword  String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([studentId])
  @@index([tutorId])
  @@index([subjectId])
}

model Message {
  id         String    @id @default(uuid())
  fromUserId String
  fromUser   User      @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  @@index([fromUserId])
  @@index([toUserId])
}

model Progress {
  id         String         @id @default(uuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  metricType String
  value      Float
  recordedAt DateTime       @default(now())
}

model ParentStudentLink {
  id         String         @id @default(uuid())
  parentId   String
  parent     User           @relation("ParentUser", fields: [parentId], references: [id])
  studentId  String
  student    User           @relation("StudentUser", fields: [studentId], references: [id])
  
  @@unique([parentId, studentId])
}

model Booking {
  id                String        @id @default(uuid())
  userId            String                          // links to the paying parent/student
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeSessionId   String        @unique           // Stripe Checkout Session ID
  stripeCustomerId  String?                         // Stripe Customer ID (for recurring lookups)
  stripePaymentIntentId String?                     // for receipt/invoice retrieval

  tier              String                          // e.g. "Platinum Path"
  subject           String                          // e.g. "GCSE Maths"
  status            BookingStatus @default(ACTIVE)

  amountPaid        Int                             // in pence (Stripe uses minor units)
  currency          String        @default("gbp")

  paidAt            DateTime      @default(now())
  lastPaymentAt     DateTime?                       // updated on recurring invoice.paid
  cancelledAt       DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
}

model TutorAvailability {
  id             String       @id @default(uuid())
  tutorProfileId String
  tutorProfile   TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  dayOfWeek      Int          // 0=Monday ... 6=Sunday
  startTime      String       // "09:00"
  endTime        String       // "17:00"

  @@index([tutorProfileId])
}

model JobOpening {
  id          String   @id @default(uuid())
  title       String
  type        String   // e.g. "Full-time / Remote"
  department  String   // e.g. "Engineering"
  description String?
  isActive    Boolean  @default(true)
  authorId    String
  author      User     @relation("JobOpenings", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([authorId])
}
