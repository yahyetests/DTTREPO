# ──────────────────────────────────────────────────────────
# Takween Tutors API — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env — only .env.example is tracked by git.
# ──────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/takween"

# JWT Secrets (REQUIRED — generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Server
CORS_ORIGIN="http://localhost:5173"
PORT=4000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLATINUM_PATH=
STRIPE_PRICE_GOLD_EDGE=
STRIPE_PRICE_SILVER_ADVANTAGE=
STRIPE_PRICE_BRONZE_BOOST=
STRIPE_PRICE_FOUNDATIONAL_FIXES=
STRIPE_PRICE_FOUNDATIONAL_FOCUS=

# Zoom (optional — for recording webhook)
# ZOOM_WEBHOOK_SECRET_TOKEN=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_ACCOUNT_ID=

# Google Drive (optional — for recording upload)
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GOOGLE_DRIVE_FOLDER_ID=
